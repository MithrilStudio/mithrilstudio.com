---
import landingScript from "../../scripts/icp/landing.js?raw";
import notFoundScript from "../../scripts/icp/not-found.js?raw";

interface Props {
  variant: "landing" | "not-found";
  className?: string;
}

const { variant, className } = Astro.props;
const script = variant === "landing" ? landingScript : notFoundScript;
---

<footer id="icpFiling" class:list={["icp-filing", className]} aria-label="ICP 备案信息">
  <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">沪ICP备2026032805号-1</a>
</footer>
<script is:inline set:html={script} />
