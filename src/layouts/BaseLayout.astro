---
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  htmlLang?: string;
  bodyClass?: string;
}

const {
  title,
  description,
  canonical,
  htmlLang = "en",
  bodyClass,
} = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
