{
  "name": "mithrilstudio.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm verify && astro build && pnpm test:output",
    "preview": "astro preview",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check --ignore-unknown .",
    "test:source": "node --test tests/legacy-contract.test.mjs tests/project-contract.test.mjs",
    "test:output": "node --test tests/output-contract.test.mjs",
    "test:browser": "playwright test --project=msedge",
    "verify": "pnpm run \"/^verify:(astro|format|source)$/\"",
    "verify:astro": "astro check",
    "verify:format": "prettier --check --ignore-unknown .",
    "verify:source": "pnpm test:source"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
